<!DOCTYPE html>
<html lang="en">
<head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <title>@ViewData["Title"] - Contoso Healthcare</title>
    <link rel="stylesheet" href="~/css/site.css" />
</head>
<body>
    <header>
        <nav class="navbar">
            <a href="/" class="nav-brand">🏥 Contoso Healthcare AI</a>
            <span class="nav-badge">Azure AI Foundry Demo</span>
        </nav>
    </header>

    <main class="main-content">
        @RenderBody()
    </main>

    <footer>
        <p>&copy; @DateTime.UtcNow.Year Contoso Healthcare — Azure AI Foundry Demo</p>
    </footer>

    @await RenderSectionAsync("Scripts", required: false)
</body>
</html>
